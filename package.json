{
  "name": "grit",
  "version": "2026.6.20-alpha",
  "description": "A simple CLI tool built with Bun",
  "author": "Sut Tuang - @johnpiapian",
  "license": "ISC",
  "type": "module",
  "bin": {
    "grit": "./bin/grit.ts"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format --check .",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "check": "bun run lint && bun run typecheck && bun test",
    "build": "bun run clean && bun build src/index.ts --outfile dist/index.js --target bun",
    "compile": "bun build src/index.ts --compile --outfile dist/grit",
    "prepack": "bun run build",
    "package": "bun pm pack"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnpiapian/grit.git"
  },
  "keywords": [
    "bun",
    "cli"
  ],
  "bugs": {
    "url": "https://github.com/johnpiapian/grit/issues"
  },
  "homepage": "https://github.com/johnpiapian/grit#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "commander": "^15.0.0"
  }
}
